# Scout — environment configuration
# Copy this file to .env and fill in the values for your environment.
# Never commit .env (it's in .gitignore).

# ─── Required ─────────────────────────────────────────────────────────────────

# Tableau Personal Access Token (PAT). Create at:
#   Cloud:  Account Settings → Personal Access Tokens
#   Server: User Settings → My Account Settings → Personal Access Tokens
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=

# Tableau site (Cloud) or content URL (Server). For Cloud, this is the part
# of the URL between /site/ and the next slash, e.g. for
# https://10ax.online.tableau.com/#/site/mycompany/home, it's "mycompany".
# For the default site on Server, leave blank.
TABLEAU_SITE=

# Tableau server URL. Examples:
#   https://10ax.online.tableau.com           (Cloud, US-East)
#   https://eu-west-1a.online.tableau.com     (Cloud, EU)
#   https://tableau.example.com               (Server)
TABLEAU_SERVER=

# Anthropic API key (for the triage agent's reasoning).
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Reliability bar (percent). Any success rate below this is treated as worth
# investigating. Default 100.0.
SCOUT_SUCCESS_TARGET=

# Set to 1 to silence the upgrade footer in Block 10's "What now?" panel.
SCOUT_NO_NAG=

# Set to 1 to read every Anthropic call from scout.db's api_cache instead of
# making live calls. Useful for offline demos and CI. Requires the cache to be
# populated by at least one prior live run.
REPLAY_MODE=

# Triage model overrides. Defaults are tuned for cost; override only if you
# want a specific stage on a different model.
SCOUT_ROUTER_MODEL=
SCOUT_SPECIALIST_FAST_MODEL=
SCOUT_SPECIALIST_DEEP_MODEL=
SCOUT_MODEL=

# How many sparse rows to backfill per agent.py run (default 200). Set to 0
# to skip the in-line hydration step entirely.
SCOUT_HYDRATE_LIMIT=
